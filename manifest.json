{
  "manifest_version": 3,
  "name": "AAtools - YouTube 助手 & 划词翻译 & 小红书增强",
  "version": "1.2.0",
  "description": "AI 驱动的 YouTube 视频总结/笔记/思维导图/词汇提取 + 全网划词翻译 + 小红书体验增强",
  "permissions": ["storage", "activeTab", "scripting", "sessions"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.minimax.io/*",
    "https://www.youtube.com/*",
    "https://api.notion.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "youtube/core.js",
        "youtube/prompts.js",
        "youtube/markdown.js",
        "youtube/export.js",
        "youtube/summary.js",
        "youtube/html-notes.js",
        "youtube/chat.js",
        "youtube/cards.js",
        "youtube/mindmap.js",
        "youtube/vocab.js",
        "youtube/panel.js"
      ],
      "css": ["youtube/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["translate/translate.js"],
      "css": ["translate/translate.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.xiaohongshu.com/*", "https://xiaohongshu.com/*"],
      "js": ["xhs/xhs-scroll-fix.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["gestures/gestures.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "options.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
